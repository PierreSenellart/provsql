PROJECT_NAME           = "ProvSQL SQL API"
PROJECT_BRIEF          = "Adding support for provenance and uncertainty management to PostgreSQL databases"

# Input
INPUT                  = ../../sql/provsql.sql mainpage-sql.md
USE_MDFILE_AS_MAINPAGE = mainpage-sql.md
RECURSIVE              = YES

# SQL-as-C parsing
FILE_PATTERNS          = *.sql
EXTENSION_MAPPING      = sql=C
OPTIMIZE_OUTPUT_FOR_C  = YES
FILTER_PATTERNS        = *.sql=./plpgsql_filter.pl

# Extraction
EXTRACT_ALL            = YES
JAVADOC_AUTOBRIEF      = YES

# Output
OUTPUT_DIRECTORY       = ../doxygen-sql
GENERATE_LATEX         = NO
GENERATE_XML           = YES
QUIET                  = YES
