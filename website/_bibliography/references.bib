  journal      = {Proc. {ACM} Manag. Data},
  volume       = {2},
  number       = {2},
  pages        = {92},
  year         = {2024},
  note         = {Presented at the PODS 2024 conference in Santiago, Chile. Also arXiv abs/2401.06493},
  doi          = {10.1145/3651593},
  pdf          = {https://pierre.senellart.com/publications/karmakar2024expected.pdf},
