@article{DBLP:journals/jair/LaiLY17,
  author       = {Yong Lai and
                  Dayou Liu and
                  Minghao Yin},
  title        = {New Canonical Representations by Augmenting {OBDDs} with
                  Conjunctive Decomposition},
  journal      = {J. Artif. Intell. Res.},
