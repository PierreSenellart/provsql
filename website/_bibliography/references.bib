  booktitle    = {Principles and Practice of Constraint Programming - 26th
                  International Conference, {CP} 2020, Louvain-la-Neuve,
                  Belgium, September 7-11, 2020, Proceedings},
  series       = {Lecture Notes in Computer Science},
  pages        = {211--230},
  publisher    = {Springer},
